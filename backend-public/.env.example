NODE_ENV=development
PORT_API=3000

# Core services (required at startup)
DATABASE_URL=postgres://user:password@localhost:5432/cryprice
BOT_TOKEN=your_telegram_bot_token

# Bot / wallets (public OSS — no tiered plans; optional override)
MAX_WALLETS_PER_USER=50

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
FLUSH_REDIS_ON_START=false

# Google Gemini AI (optional — needed only for `ai:` bot replies)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# Google Sign-In + API JWT (optional — omit or leave placeholders to disable REST auth wiring gracefully per routes)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
JWT_ACCESS_SECRET=replace_with_32_plus_random_chars
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=604800
JWT_ISSUER=cryprice-api
JWT_AUDIENCE=cryprice-clients

# Ethereum Mainnet
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
ETHEREUM_AAVE_ADDRESSES_PROVIDER=0x2f39d218133AFaB8F2B819B1066c7E434Ad94E9e
ETHEREUM_AAVE_POOL_DATA_PROVIDER=0x91c0ea31b49b69ea18607702c5d9ac360bf3de7d
ETHEREUM_EXPLORER=https://api.etherscan.io/
ETHEREUM_EXPLORER_KEY=your_etherscan_api_key

# Arbitrum Mainnet
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_AAVE_ADDRESSES_PROVIDER=0xa97684ead0e402dC232d5A977953DF7ECBaB3CDb
ARBITRUM_AAVE_POOL_DATA_PROVIDER=0x145de30c929a065582da84cf96f88460db9745a7
ARBITRUM_EXPLORER=https://api.etherscan.io/
ARBITRUM_EXPLORER_KEY=your_arbitrum_explorer_api_key

# Avalanche Mainnet
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_AAVE_ADDRESSES_PROVIDER=0xa97684ead0e402dC232d5A977953DF7ECBaB3CDb
AVALANCHE_AAVE_POOL_DATA_PROVIDER=0x50B4a66bF4D41e6252540eA7427D7A933Bc3c088
AVALANCHE_EXPLORER=https://api.snowtrace.io/
AVALANCHE_EXPLORER_KEY=your_snowtrace_api_key

# Base Mainnet
BASE_RPC_URL=https://mainnet.base.org
BASE_AAVE_ADDRESSES_PROVIDER=0xe20fcbdbffc4dd138ce8b2e6fbb6cb49777ad64d
BASE_AAVE_POOL_DATA_PROVIDER=0xe20fCBdBfFC4Dd138cE8b2E6FBb6CB49777ad64D
BASE_EXPLORER=https://api.basescan.org/
BASE_EXPLORER_KEY=your_base_explorer_api_key
