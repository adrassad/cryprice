# This project does not load these keys from disk at runtime.
# Pass values at compile time with Flutter’s --dart-define (see DEVELOPMENT.md).
#
# Example:
#   flutter run -d chrome \
#     --dart-define=CRYPRICE_BACKEND_BASE_URL=https://your-api.example \
#     --dart-define=AUTH_BACKEND_BASE_URL=https://your-auth.example \
#     --dart-define=GOOGLE_WEB_CLIENT_ID=your-id.apps.googleusercontent.com

# Aggregated prices API (OffchainOnchainPricesClient)
CRYPRICE_BACKEND_BASE_URL=

# Auth API (/auth/google, /auth/me, refresh, logout) — often the same host as prices in dev
AUTH_BACKEND_BASE_URL=

# Google Sign-In (Web / optional Android server client id)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_SERVER_CLIENT_ID=
