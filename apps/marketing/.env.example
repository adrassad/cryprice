# Optional public marketing URLs. If unset, defaults in `src/siteContent.ts` apply
# (official CryPrice deployment). Use this file when forking or pointing at staging.

VITE_PUBLIC_APP_URL=https://example.com
VITE_PUBLIC_API_HOST=api.example.com
VITE_PUBLIC_MONOREPO_URL=https://github.com/example/cryprice
VITE_PUBLIC_WEB_APP_PATH_URL=https://github.com/example/cryprice/tree/main/apps/web
VITE_PUBLIC_BACKEND_PATH_URL=https://github.com/example/cryprice/tree/main/backend-public
VITE_PUBLIC_GITHUB_PROFILE_URL=https://github.com/example
VITE_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/example
VITE_PUBLIC_X_PROFILE_URL=https://x.com/example

# Reserved for future analytics (add when you wire a provider)
# VITE_PUBLIC_GA_MEASUREMENT_ID=your_analytics_id_here
# VITE_PUBLIC_GTM_ID=your_gtm_id_here
# VITE_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
# VITE_PUBLIC_POSTHOG_KEY=your_posthog_key_here
